{
  "name": "afric-luxe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx concurrently -k -n api,vite \"npx tsx watch server/index.ts\" \"npx vite --port=3000 --host=0.0.0.0\"",
    "dev:vite": "npx vite --port=3000 --host=0.0.0.0",
    "build": "npx vite build && npx tsc -p tsconfig.server.json",
    "start": "cross-env NODE_ENV=production node dist-server/index.js",
    "preview": "npx vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.13.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
